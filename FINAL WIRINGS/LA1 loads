---
config:
  flowchart:
    nodeSpacing: 20
    rankSpacing: 20
  theme: base
  layout: dagre
---
flowchart LR
 subgraph PSUS["PSUs"]
    direction TB
        PSU_LA1["LA #1 PSU (24VDC)"]
        PSU_LA2["LA #2 PSU (24VDC)"]
        PSU_PMP["Pumps PSU (12VDC)"]
        PSU_CTRL["Controls PSU (24VDC)"]
  end

 subgraph LA1_LOADS["LA #1 PSU (24VDC) → LOADS"]
    direction LR
        PD_LA1_POS["+24V power distribution"]
        PD_LA1_NEG["0V return bus"]

        subgraph BRANCH_FUSES["Branch fuses (+24V)"]
          direction TB
            FUSE_FA["3A fuse (Fan Group A)"]
            FUSE_FB["3A fuse (Fan Group B)"]
            FUSE_CONV_TBM["3A fuse (Converter TBM input)"]
            FUSE_CONV_CP["3A fuse (Converter Panel input)"]
            BRK_LA1["25A DC breaker"]
        end

        subgraph STEP_DOWNS["Step downs"]
          direction TB
            CONV_TBM["24V → 5V Converter (TBM)"]
            CONV_CP["24V → 5V Converter (Control Panel)"]
        end

        subgraph CKT_PROT["Circuit protection"]
          direction TB
            FUSE_TBM["3A Fuse (TBM Logic)"]
            FUSE_CP["3A Fuse (Panel Logic)"]
        end

        subgraph SWITCHES["Switches"]
          direction TB
            K_FAN_A["13.5A relay (Fan Group A)"]
            K_FAN_B["13.5A relay (Fan Group B)"]
        end

        subgraph BUSES["Buses"]
          direction TB
            BUS_A_POS["+24V bus A (Fans 1, 2)"]
            BUS_B_POS["+24V bus B (Fans 3, 4)"]
        end

        subgraph LOADS["Loads"]
          direction TB
            FAN1["TBM fan 1 (24V, 1A)"]
            FAN2["TBM fan 2 (24V, 1A)"]
            FAN3["TBM fan 3 (24V, 1A)"]
            FAN4["TBM fan 4 (24V, 1A)"]
            LA1["Linear Actuator #1"]
            ESP_TBM["TBM ESP32"]
            ESP_CP["Control Panel ESP32"]
        end
  end

%% ===== LINKS (INDEXED 0–30) =====

    PSU_LA1 -- +24V --> PD_LA1_POS        %% 0
    PD_LA1_NEG -- 0V --> PSU_LA1          %% 1

    PD_LA1_POS -- +24V --> FUSE_FA        %% 2
    PD_LA1_POS -- +24V --> FUSE_FB        %% 3
    PD_LA1_POS -- +24V --> FUSE_CONV_TBM  %% 4
    PD_LA1_POS -- +24V --> FUSE_CONV_CP   %% 5
