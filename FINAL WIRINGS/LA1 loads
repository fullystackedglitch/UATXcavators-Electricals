    FUSE_FA -- +24V --> K_FAN_A           %% 7
    K_FAN_A -- +24V --> BUS_A_POS         %% 8
    BUS_A_POS -- +24V --> FAN1            %% 9
    BUS_A_POS -- +24V --> FAN2            %% 10
    FAN1 -- 0V --> PD_LA1_NEG             %% 11
    FAN2 -- 0V --> PD_LA1_NEG             %% 12

    FUSE_FB -- +24V --> K_FAN_B           %% 13
    K_FAN_B -- +24V --> BUS_B_POS         %% 14
    BUS_B_POS -- +24V --> FAN3            %% 15
    BUS_B_POS -- +24V --> FAN4            %% 16
    FAN3 -- 0V --> PD_LA1_NEG             %% 17
    FAN4 -- 0V --> PD_LA1_NEG             %% 18

    BRK_LA1 -- +24V --> LA1               %% 19
    LA1 -- 0V --> PD_LA1_NEG              %% 20

    FUSE_CONV_TBM -- +24V --> CONV_TBM    %% 21
    CONV_TBM -- 0V --> PD_LA1_NEG         %% 22

    FUSE_CONV_CP -- +24V --> CONV_CP      %% 23
    CONV_CP -- 0V --> PD_LA1_NEG          %% 24

    CONV_TBM -- +5V --> FUSE_TBM          %% 25
    FUSE_TBM -- +5V --> ESP_TBM           %% 26
    ESP_TBM -- 0V --> CONV_TBM            %% 27

    CONV_CP -- +5V --> FUSE_CP            %% 28
    FUSE_CP -- +5V --> ESP_CP             %% 29
    ESP_CP -- 0V --> CONV_CP              %% 30


